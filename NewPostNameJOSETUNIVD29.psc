//verificar si un numero es positivo
//o negativo
Algoritmo sin_titulo
	//Entrada
	Escribir "==NUMERO POSITIVOS Y NEGATIVOS=="
    Definir num Como Entero
	Escribir "Dame un numero entero:"
	Leer num
	
	//Proceso 
	//Salida
	Si num>=0 Entonces
		Escribir "Es un numero POSTIVO"
	SiNo
		Escribir "Es un numero NEGATIVO"
	Fin Si
FinAlgoritmo
